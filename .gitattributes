# ──────────────────────────────
# Core normalization
# ──────────────────────────────
* text=auto eol=lf

# Always use LF line endings (macOS/Linux standard)
*.sh     text eol=lf
*.zsh    text eol=lf
*.bash   text eol=lf
*.lua    text eol=lf
*.toml   text eol=lf
*.conf   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf

# ──────────────────────────────
# Binary files (no diff, no text conversion)
# ──────────────────────────────
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.icns   binary
*.ttf    binary
*.otf    binary
*.woff*  binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.tar    binary
*.mov    binary
*.mp4    binary

# ──────────────────────────────
# Git attributes for better diffs
# ──────────────────────────────
*.md     diff=markdown
*.toml   diff=toml
*.json   diff=json
*.lua    diff=lua
*.zsh    diff=sh
*.sh     diff=sh
*.conf   diff=ini
*.yml    diff=yaml
*.yaml   diff=yaml

# ──────────────────────────────
# macOS metadata and system files
# ──────────────────────────────
.DS_Store export-ignore
.AppleDouble export-ignore
._* export-ignore
