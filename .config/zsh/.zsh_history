cd ~
echo "ZDOTDIR=$ZDOTDIR"\
for p in "$HOME/.config/zsh" "$HOME/.config/nvim" "$HOME/.config/starship.toml"; do\
  [ -L "$p" ] && echo "OK  $p -> $(readlink "$p")" || echo "MISSING $p"\
done\
test -r "$HOME/.config/zsh/.zshrc" && echo "zshrc found 窿ｼΗ" || echo "zshrc missing 窿ｽΞ"
echo "ZDOTDIR=$ZDOTDIR"\
for p in "$HOME/.config/zsh" "$HOME/.config/nvim" "$HOME/.config/starship.toml"; do\
  [ -L "$p" ] && echo "OK  $p -> $(readlink "$p")" || echo "MISSING $p"\
done\
test -r "$HOME/.config/zsh/.zshrc" && echo "zshrc found 窿ｼΗ" || echo "zshrc missing 窿ｽΞ"
ls -1dt ~/dotfiles_backup_* 2>/dev/null | tail -n +3 | xargs -I{} rm -rf "{}"
nano ~/seed_zsh_config.sh
chmod +x ~/seed_zsh_config.sh\
zsh ~/seed_zsh_config.sh\
exec zsh
