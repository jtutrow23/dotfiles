# ~/dotfiles/bin/sanity

#!/usr/bin/env bash
zsh -lic '
echo "🔍 Running dotfiles sanity check (interactive login)…"
print "ZDOTDIR=${ZDOTDIR:-<unset>}"

typeset -f znap >/dev/null && echo "✅ Znap loaded" || echo "❌ Znap missing"
alias gs >/dev/null 2>&1 && echo "✅ Aliases sourced" || echo "❌ Aliases not sourced"
whence -w mkcd >/dev/null 2>&1 && echo "✅ Functions sourced" || echo "❌ Functions not sourced"

command -v starship >/dev/null 2>&1 && echo "✅ Starship found" || echo "⚠️ Starship not installed"
[[ -L "$HOME/.config/zsh" || -d "$HOME/.config/zsh" ]] && echo "✅ $HOME/.config/zsh present" || echo "❌ $HOME/.config/zsh missing"
[[ -e "$HOME/.config/nvim" ]] && echo "✅ $HOME/.config/nvim present" || echo "❌ $HOME/.config/nvim missing"
[[ -e "$HOME/.config/starship.toml" ]] && echo "✅ $HOME/.config/starship.toml present" || echo "❌ $HOME/.config/starship.toml missing"

echo "✨ Sanity check complete."
'

# --- Git cleanliness check ---
if [ -d "$HOME/dotfiles/.git" ]; then
  echo "🔍 Checking git status…"
  cd "$HOME/dotfiles" || exit
  if git diff --quiet && git diff --cached --quiet && [ -z "$(git status --porcelain --untracked-files=no)" ]; then
    echo "✅ Git repo clean (no unstaged or staged changes)"
  else
    echo "⚠️ Git repo has uncommitted changes or untracked files"
    git status -s
  fi
  cd - >/dev/null || true
fi
