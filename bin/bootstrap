#!/usr/bin/env zsh
set -euo pipefail
cd "$HOME/dotfiles" || { echo "dotfiles repo not found"; exit 1; }
[[ -x ./setup_dotfiles.sh ]] && zsh ./setup_dotfiles.sh || echo "setup_dotfiles.sh missing"
if command -v brew >/dev/null; then brew bundle --file="$HOME/dotfiles/Brewfile" || true; else echo "Homebrew not installed"; fi
[[ -x ./macos_bootstrap.sh ]] && zsh ./macos_bootstrap.sh || echo "macos_bootstrap.sh missing (ok)"
[[ -x "$HOME/dotfiles/bin/sanity" ]] && "$HOME/dotfiles/bin/sanity" || echo "sanity missing (ok)"
echo "Bootstrap complete. Now: exec zsh"
