# ──────────────────────────────
# macOS system cruft
# ──────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
__MACOSX
._*

# ──────────────────────────────
# Zsh / shell caches
# ──────────────────────────────
*.zwc
*.zwc.old
.zcompdump*
.zsh_sessions/
.zsh_history
.zsh_history.old
.cache/
local.zsh
session.*

# ──────────────────────────────
# Logs, swap, temp
# ──────────────────────────────
*.log
*.tmp
*.bak
*.swp
*.swo
*.orig

# ──────────────────────────────
# Node / Python / build caches
# ──────────────────────────────
node_modules/
dist/
build/
__pycache__/
*.pyc
.env
.envrc
venv/
.venv/

# ──────────────────────────────
# Starship / tool-specific
# ──────────────────────────────
*.toml.bak
*.lock
*.old
starship.log

# ──────────────────────────────
# Editors / IDEs
# ──────────────────────────────
.vscode/
.idea/
.netrwhist

# ──────────────────────────────
# iTerm2 (local integration, autogenerated)
# ──────────────────────────────
zsh/.iterm2/
zsh/.iterm2_shell_integration.zsh

# ──────────────────────────────
# Misc
# ──────────────────────────────
*.icloud
# Neovim runtime noise
.config/nvim/lazy-lock.json
.config/nvim_backup_*
Documents/Configs/Mackup/

